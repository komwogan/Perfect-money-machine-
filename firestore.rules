rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Comment Validation ---
    function isValidComment(data) {
      return data.keys().hasAll(['name', 'email', 'text', 'createdAt']) 
        && data.keys().size() >= 4
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 100
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 150
        && data.text is string && data.text.size() >= 1 && data.text.size() <= 1000
        && data.createdAt == request.time;
    }

    // --- Collections ---
    match /_connection_test_/{docId} {
      allow read: if true;
    }

    match /comments/{commentId} {
      allow read: if true; // Publicly readable
      allow create: if isValidId(commentId) && isValidComment(incoming());
      allow update, delete: if false; // Immutable comments for now
    }
  }
}
